{
  "testId": "bolt-express",
  "name": "Bolt Express",
  "version": "0.0.20",
  "manifestVersion": 2,
  "requirements": {
    "apps": [
      {
        "name": "Express",
        "apiVersion": 1
      }
    ]
  },
  "entryPoints": [
    {
      "type": "panel",
      "id": "panel1",
      "main": "index.html",
      "documentSandbox": "code.js",
      "permissions": {
        "sandbox": [
          "allow-popups",
          "allow-popups-to-escape-sandbox",
          "allow-presentation",
          "allow-downloads"
        ],
        "oauth": [
          "*"
        ]
      }
    }
  ]
}